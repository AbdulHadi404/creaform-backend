{
    "compilerOptions": {
        "module": "commonjs",
        "moduleResolution": "node10",
        "esModuleInterop": true,
        "isolatedModules": true,
        "declaration": true,
        "removeComments": true,
        "emitDecoratorMetadata": true,
        "experimentalDecorators": true,
        "allowSyntheticDefaultImports": true,
        "target": "es2023",
        "sourceMap": true,
        "outDir": "./dist",
        "rootDir": "./src",
        "baseUrl": "./",
        "paths": {
            "@/*": [
                "src/*"
            ]
        },
        "incremental": true,
        "skipLibCheck": true,
        "strictNullChecks": true,
        "forceConsistentCasingInFileNames": true,
        "noImplicitAny": false,
        "strictBindCallApply": false,
        "noFallthroughCasesInSwitch": false,
        "preserveConstEnums": true,
        "useDefineForClassFields": true
    },
    "files": [
        "./drizzle.config.d.ts",
        "./src/app.controller.spec.ts",
        "./src/app.controller.ts",
        "./src/app.module.ts",
        "./src/app.service.ts",
        "./src/main.ts",
        "./src/common/filters/all-exceptions.filter.ts",
        "./src/common/pipes/parse-positive-int.pipe.ts",
        "./src/config/env.validation.ts",
        "./src/database/database.module.ts",
        "./src/database/schema.ts",
        "./src/modules/contacts/contacts.controller.ts",
        "./src/modules/contacts/contacts.dto.ts",
        "./src/modules/contacts/contacts.module.ts",
        "./src/modules/contacts/contacts.service.ts",
        "./src/modules/health/health.controller.ts",
        "./src/modules/health/health.module.ts",
        "./src/modules/import/import.module.ts",
        "./src/modules/notes/notes.controller.ts",
        "./src/modules/notes/notes.dto.ts",
        "./src/modules/notes/notes.module.ts",
        "./src/modules/notes/notes.service.ts",
        "./src/modules/prospects/prospects.controller.ts",
        "./src/modules/prospects/prospects.dto.ts",
        "./src/modules/prospects/prospects.module.ts",
        "./src/modules/prospects/prospects.service.ts",
        "./src/modules/sdrs/sdrs.controller.ts",
        "./src/modules/sdrs/sdrs.dto.ts",
        "./src/modules/sdrs/sdrs.module.ts",
        "./src/modules/sdrs/sdrs.service.ts",
        "./src/modules/sequences/sequence-template.ts",
        "./src/modules/sequences/sequences.controller.ts",
        "./src/modules/sequences/sequences.dto.ts",
        "./src/modules/sequences/sequences.module.ts",
        "./src/modules/sequences/sequences.service.ts",
        "./src/types/express-global.d.ts"
    ],
    "exclude": [
        "drizzle.config.ts",
        "test"
    ]
}
