# ─── Neon Postgres ────────────────────────────────────────────────────────────
# Get this from: https://console.neon.tech → your project → Connection string
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/creaform?sslmode=require"

# ─── App ──────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Your frontend URL (Vercel preview or local)
FRONTEND_URL=http://localhost:5173

# ─── Upload limits ────────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=20
